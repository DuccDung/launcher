@{
    Layout = null;
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập | Deluxe Gaming</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth-page.css" asp-append-version="true" />
</head>
<body>
    <div class="ambient-glow" aria-hidden="true">
        <span class="ambient-glow__halo"></span>
        <span class="ambient-glow__core"></span>
    </div>

    <div class="page-shell">
        <header class="header-wrapper">
            <div class="header-top">
                <div class="container topbar">
                    <div class="marquee" aria-label="Thông báo người dùng trúng thưởng">
                        <div class="marquee-track">
                            <span class="marquee-item">Chúc mừng Thanh Tùng vừa trúng <strong>Assassin's Creed Mirage</strong> khi mở Mystery Box Ultimate. Thử vận may ngay!</span>
                            <span class="marquee-item">Chúc mừng Khánh Toàn vừa trúng <strong>Black Myth Wukong</strong> khi mở Mystery Box Ultimate. Thử vận may ngay!</span>
                            <span class="marquee-item">Chúc mừng Minh Khang vừa trúng <strong>God of War Ragnarok</strong> khi mở Mystery Box Ultimate. Thử vận may ngay!</span>
                            <span class="marquee-item">Chúc mừng Thanh Tùng vừa trúng <strong>Assassin's Creed Mirage</strong> khi mở Mystery Box Ultimate. Thử vận may ngay!</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="header-main">
                <div class="header-inner container" role="navigation" aria-label="Điều hướng chính">
                    <div class="show-for-medium flex-left">
                        <button id="mobileMenuToggle" class="menu-toggle-btn" type="button" aria-label="Mở menu" aria-controls="mobileDrawer" aria-expanded="false">
                            <i class="bi bi-list"></i>
                        </button>
                    </div>

                    <div class="logo">
                        <a href="/" title="Deluxe Gaming" rel="home" class="logo-link">
                            <img src="https://deluxegaming.vn/wp-content/uploads/2025/11/logo-deluxe-1024x202.png" alt="Deluxe Gaming" class="header-logo" />
                        </a>
                    </div>

                    <div class="hide-for-medium flex-right">
                        <ul class="header-nav nav-right">
                            <li class="account-item has-icon">
                                <a href="/auth" class="nav-top-link" title="Đăng nhập">
                                    <span>Đăng nhập</span>
                                </a>
                            </li>
                            <li class="cart-item has-icon">
                                <a href="#" class="header-cart-link" title="Giỏ hàng">
                                    <span class="header-cart-title">Giỏ hàng</span>
                                    <i class="fa-solid fa-basket-shopping" data-icon-label="1"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="header-bottom">
                <div class="container wide-nav-inner">
                    <nav class="wide-nav-nav" aria-label="Danh mục sản phẩm">
                        <ul class="header-bottom-nav">
                            <li><a href="/" class="nav-link-item">Trang chủ</a></li>
                            <li><a href="#" class="nav-link-item">Giới thiệu</a></li>
                            <li><a href="#" class="nav-link-item">Thể loại</a></li>
                            <li><a href="#" class="nav-link-item">Blog</a></li>
                            <li><a href="#" class="nav-link-item">Liên hệ</a></li>
                        </ul>
                    </nav>

                    <div class="search-area">
                        <form class="searchform" action="#" method="get">
                            <div class="searchform-wrapper">
                                <input class="search-field" type="search" placeholder="Tìm kiếm..." aria-label="Tìm kiếm sản phẩm" />
                                <button class="search-submit" type="submit" aria-label="Tìm">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </header>

        <main class="auth-page-main">
            <section class="auth-section" aria-labelledby="authPageTitle">
                <div class="container">
                    <div class="auth-shell">
                        <div class="auth-grid">
                            <section class="auth-card" aria-labelledby="loginTitle">
                                <div class="auth-card-head">
                                    <h2 id="loginTitle" class="auth-card-title">Đăng nhập</h2>
                                </div>

                                <form id="loginForm" class="auth-form" novalidate>
                                    <div class="auth-field">
                                        <label for="authLoginEmail">Tên tài khoản hoặc địa chỉ email *</label>
                                        <input id="authLoginEmail" type="email" name="login_email" autocomplete="username" />
                                    </div>

                                    <div class="auth-field">
                                        <label for="authLoginPassword">Mật khẩu *</label>
                                        <input id="authLoginPassword" type="password" name="login_password" autocomplete="current-password" />
                                    </div>

                                    <label class="auth-check">
                                        <input type="checkbox" name="remember_me" />
                                        <span>Ghi nhớ mật khẩu</span>
                                    </label>

                                    <div class="auth-actions">
                                        <button class="auth-button auth-button--primary" type="submit">Đăng nhập</button>
                                    </div>

                                    <p id="loginMessage" class="auth-status" aria-live="polite"></p>
                                    <a href="#" class="auth-link-inline">Quên mật khẩu?</a>
                                </form>
                            </section>

                            <section class="auth-card auth-card--register" aria-labelledby="registerTitle">
                                <div class="auth-card-head">
                                    <h2 id="registerTitle" class="auth-card-title">Đăng ký</h2>
                                </div>

                                <form id="registerForm" class="auth-form" novalidate>
                                    <div class="auth-field">
                                        <label for="authRegisterEmail">Địa chỉ email *</label>
                                        <input id="authRegisterEmail" type="email" name="register_email" autocomplete="email" />
                                    </div>

                                    <div class="auth-field">
                                        <label for="authRegisterPassword">Mật khẩu *</label>
                                        <input id="authRegisterPassword" type="password" name="register_password" autocomplete="new-password" />
                                    </div>

                                    <div class="auth-field">
                                        <label for="authRegisterConfirm">Nhập lại mật khẩu *</label>
                                        <input id="authRegisterConfirm" type="password" name="register_confirm_password" autocomplete="new-password" />
                                    </div>

                                    <div class="auth-field">
                                        <label for="authRegisterDisplayName">Tên hiển thị</label>
                                        <input id="authRegisterDisplayName" type="text" name="display_name" autocomplete="nickname" />
                                    </div>

                                    <div class="auth-actions">
                                        <button class="auth-button auth-button--primary" type="submit">Đăng ký</button>
                                    </div>

                                    <p id="registerMessage" class="auth-status" aria-live="polite"></p>
                                </form>
                            </section>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <div id="mobileOverlay" class="mobile-menu-overlay"></div>

        <aside id="mobileDrawer" class="mobile-menu-drawer" aria-hidden="true" aria-label="Menu di động">
            <div class="mobile-drawer-header">
                <span>Danh mục</span>
                <button id="closeDrawer" type="button" aria-label="Đóng menu">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <nav class="mobile-drawer-nav" aria-label="Điều hướng di động">
                <ul>
                    <li><a href="/">Trang chủ</a></li>
                    <li><a href="#">Steam Wallet</a></li>
                    <li><a href="#">Gift Card</a></li>
                    <li><a href="#">Mystery Box</a></li>
                    <li><a href="/auth">Đăng nhập</a></li>
                </ul>
            </nav>
        </aside>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth-page.js" asp-append-version="true"></script>
</body>
</html>
