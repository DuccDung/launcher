@{
    ViewData["Title"] = "Deluxe Gaming";
}

<div class="festival-shell">
    <aside class="festival-rail festival-rail-left" aria-hidden="true">
        <div class="rail-ornament rail-blossom"></div>
        <div class="rail-banner">
            <span>Nam</span>
            <span>Moi</span>
            <span>Hanh</span>
            <span>Phuc</span>
            <span>Binh</span>
            <span>An</span>
        </div>
        <div class="rail-lantern"></div>
    </aside>

    <aside class="festival-rail festival-rail-right" aria-hidden="true">
        <div class="rail-ornament rail-apricot"></div>
        <div class="rail-banner">
            <span>Ngay</span>
            <span>Xuan</span>
            <span>Vinh</span>
            <span>Hoa</span>
            <span>Phu</span>
            <span>Quy</span>
        </div>
        <div class="rail-lantern"></div>
    </aside>

    <div class="floating-particles" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
    </div>

    <section class="top-marquee">
        <div class="top-marquee__track" id="winnerTicker">
            <span>Chuc mung Hoang Nam vua trung God of War Ragnarok khi mo Mystery Box Ultimate.</span>
            <span>Chuc mung Thanh Tung vua trung Resident Evil 4 Remake tu vong quay may man.</span>
            <span>Play more, spend less voi uu dai Tet Deluxe Gaming len den 40%.</span>
            <span>Nap vi nhanh, nhan key game sieu toc trong 5 phut.</span>
        </div>
    </section>

    <div class="page-frame">
        <header class="hero-header">
            <div class="hero-header__top">
                <a class="brand-card" href="#">
                    <div class="brand-card__logo">DG</div>
                    <div>
                        <div class="brand-card__name">Deluxe Gaming</div>
                        <div class="brand-card__tag">Play more, spend less</div>
                    </div>
                </a>

                <div class="hero-actions">
                    <a href="#" class="hero-link">Dang nhap</a>
                    <a href="#" class="hero-button">Gio hang <span>3</span></a>
                </div>
            </div>

            <div class="hero-header__bottom">
                <nav class="main-nav">
                    <a href="#">Trang chu</a>
                    <a href="#">Gioi thieu</a>
                    <a href="#">The loai</a>
                    <a href="#">Blog</a>
                    <a href="#">Yeu thich</a>
                    <a href="#">Vong quay may man</a>
                    <a href="#">Lien he</a>
                </nav>

                <label class="search-box" aria-label="Tim kiem">
                    <input type="text" placeholder="Tim kiem..." />
                    <button type="button">Go</button>
                </label>
            </div>
        </header>

        <main class="landing-content">
            <section class="promo-banner">
                <div class="promo-wheel">
                    <div class="promo-wheel__center"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--1"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--2"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--3"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--4"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--5"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--6"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--7"></div>
                    <div class="promo-wheel__slice promo-wheel__slice--8"></div>
                </div>

                <div class="promo-copy">
                    <span class="promo-chip">Le hoi mua xuan 2026</span>
                    <h1>Vong quay Deluxe Gaming</h1>
                    <p>Quay loc lien tay, nhan ngay qua khung cung uu dai key game, gift card va mystery box.</p>
                    <div class="promo-actions">
                        <a href="#" class="btn-primary-glow">Choi ngay</a>
                        <a href="#" class="btn-secondary-ghost">Xem uu dai</a>
                    </div>
                </div>
            </section>

            <section class="section-heading">
                <span></span>
                <h2>Kham pha game moi</h2>
                <span></span>
            </section>

            <section class="discover-grid">
                <article class="feature-card">
                    <div class="feature-card__media">
                        <div class="feature-card__badge">Pre-order</div>
                        <div class="feature-card__title-group">
                            <p class="feature-card__eyebrow">Racing collection</p>
                            <h3>Forza Horizon 6</h3>
                            <p>Steam Key Online | Ban Deluxe | Qua tang skin mua xuan</p>
                        </div>
                    </div>

                    <div class="feature-card__content">
                        <div class="feature-stat">
                            <strong>1.299.000 VND</strong>
                            <span>Giao key tu dong sau thanh toan</span>
                        </div>
                        <div class="feature-stat">
                            <strong>4.9/5</strong>
                            <span>2.4k danh gia tich cuc</span>
                        </div>
                        <div class="feature-stat">
                            <strong>Bonus Tet</strong>
                            <span>Voucher 100k cho don hang tiep theo</span>
                        </div>
                    </div>
                </article>

                <aside class="side-list" id="sideGameList">
                    <article class="side-item is-active">
                        <div class="side-item__thumb side-item__thumb--forza"></div>
                        <div>
                            <h3>Forza Horizon 6</h3>
                            <p>Steam Key Online | Pre-order</p>
                        </div>
                    </article>
                    <article class="side-item">
                        <div class="side-item__thumb side-item__thumb--bond"></div>
                        <div>
                            <h3>007 First Light</h3>
                            <p>Key Steam | Ban dac biet</p>
                        </div>
                    </article>
                    <article class="side-item">
                        <div class="side-item__thumb side-item__thumb--evil"></div>
                        <div>
                            <h3>Resident Evil Requiem</h3>
                            <p>Steam Key | Viet hoa san</p>
                        </div>
                    </article>
                    <article class="side-item">
                        <div class="side-item__thumb side-item__thumb--desert"></div>
                        <div>
                            <h3>Crimson Desert</h3>
                            <p>Action RPG | Pre-order gift</p>
                        </div>
                    </article>
                </aside>
            </section>
        </main>
    </div>

    <div class="floating-toast" id="purchaseToast">
        <div class="floating-toast__thumb"></div>
        <div>
            <p class="floating-toast__title">Hoang Nam da them vao gio</p>
            <p class="floating-toast__text">Drive Beyond Horizons - Key Steam Deluxe Edition</p>
        </div>
        <button type="button" class="floating-toast__close" aria-label="Dong">x</button>
    </div>

    <div class="floating-contact">
        <button type="button" class="contact-pill">Lien he</button>
        <button type="button" class="spin-pill" aria-label="Mo vong quay mini">
            <span></span>
        </button>
    </div>
</div>
